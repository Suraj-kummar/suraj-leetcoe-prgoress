class Solution {
    public int numSpecial(int[][] mat) {
        int m = mat.length;
        int n = mat[0].length;
        
        int[] rowOnes = new int[m];
        int[] colOnes = new int[n];
        
        // Step 1: Count the 1s in each row and column
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                if (mat[i][j] == 1) {
                    rowOnes[i]++;
                    colOnes[j]++;
                }
            }
        }
        
        // Step 2: Check for special positions
        int specialCount = 0;
        for (int i = 0; i < m; i++) {
            for (int j = 0; j < n; j++) {
                // A position is special if it's 1, and it's the only 1 in its row and column
                if (mat[i][j] == 1 && rowOnes[i] == 1 && colOnes[j] == 1) {
                    specialCount++;
                }
            }
        }
        
        return specialCount;
    }
}
