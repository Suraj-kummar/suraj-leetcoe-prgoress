class Solution {
    public boolean checkOnesSegment(String s) {
        // Loop from the second character to the end
        for (int i = 1; i < s.length(); i++) {
            // Check if the current character is '1' and the previous was '0'
            if (s.charAt(i - 1) == '0' && s.charAt(i) == '1') {
                return false; 
            }
        }
        return true;
    }
}