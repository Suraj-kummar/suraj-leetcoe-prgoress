class Solution {
    public boolean isIsomorphic(String s, String t) {
        // Use arrays to store the last seen positions (index + 1)
        // Size 256 covers all standard ASCII characters
        int[] mapS = new int[256];
        int[] mapT = new int[256];

        for (int i = 0; i < s.length(); i++) {
            char charS = s.charAt(i);
            char charT = t.charAt(i);

            // If the previous positions don't match, they aren't mapping correctly
            if (mapS[charS] != mapT[charT]) {
                return false;
            }

            // Update the position (using i + 1 because 0 is the default value)
            mapS[charS] = i + 1;
            mapT[charT] = i + 1;
        }

        return true;
    }
}
