class Solution {
    public int[][] constructProductMatrix(int[][] grid) {
        int n = grid.length;
        int m = grid[0].length;
        int[][] p = new int[n][m];
        int MOD = 12345;
        
        long runningProduct = 1;
        
        // Step 1: Forward Pass (Prefix Product)
        // Store the product of all elements before grid[i][j]
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                p[i][j] = (int) (runningProduct % MOD);
                runningProduct = (runningProduct * (grid[i][j] % MOD)) % MOD;
            }
        }
        
        runningProduct = 1;
        
        // Step 2: Backward Pass (Suffix Product)
        // Multiply the existing prefix product by the product of all elements after grid[i][j]
        for (int i = n - 1; i >= 0; i--) {
            for (int j = m - 1; j >= 0; j--) {
                p[i][j] = (int) ((p[i][j] * runningProduct) % MOD);
                runningProduct = (runningProduct * (grid[i][j] % MOD)) % MOD;
            }
        }
        
        return p;
    }
}
